@{
    ViewData["Title"] = "Contact Us";
}

<div class="container my-5">
    <div class="row g-5">
        <div class="col-md-5">
            <h2 class="fw-bold text-warning mb-4">Get In Touch</h2>
            <p class="text-muted mb-4">Have a question about our handbags or clothing materials? Our team is here to help you.</p>
            
            <div class="d-flex mb-3">
                <i class="fas fa-map-marker-alt text-warning fs-4 me-3"></i>
                <p>Colombo, Sri Lanka</p>
            </div>
            <div class="d-flex mb-3">
                <i class="fas fa-envelope text-warning fs-4 me-3"></i>
                <p>support@luxefem.com</p>
            </div>
            <div class="d-flex mb-4">
                <i class="fas fa-phone text-warning fs-4 me-3"></i>
                <p>+94 112 345 678</p>
            </div>

            <div class="p-4 bg-light rounded shadow-sm">
                <h6 class="fw-bold">Business Hours</h6>
                <p class="small text-muted mb-0">Monday - Friday: 9:00 AM - 6:00 PM</p>
                <p class="small text-muted">Saturday: 10:00 AM - 2:00 PM</p>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card border-0 shadow p-4">
                <form>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Full Name</label>
                            <input type="text" class="form-control" placeholder="Your Name">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email Address</label>
                            <input type="email" class="form-control" placeholder="name@example.com">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Subject</label>
                            <select class="form-select">
                                <option>Order Status</option>
                                <option>Product Inquiry</option>
                                <option>Returns</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Message</label>
                            <textarea class="form-control" rows="5" placeholder="How can we help you?"></textarea>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-dark w-100 py-2">Send Message</button>
                        </div>
                    </div>
                </form>

                <div class="row mt-5">
    <div class="col-12">
        <h4 class="fw-bold mb-3">Visit Our Shop</h4>
        <div class="shadow-sm rounded overflow-hidden">
            <iframe 
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d126743.58290458638!2d79.786164!3d6.921837!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3ae2593cf65a1e9d%3A0xe130cfe21851b97e!2sColombo!5e0!3m2!1sen!2slk!4v1711300000000!5m2!1sen!2slk" 
                width="100%" 
                height="400" 
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy">
            </iframe>
        </div>
    </div>
</div>


            </div>
        </div>
    </div>
</div>