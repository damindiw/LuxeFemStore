@model IEnumerable<LuxeFemStore.Models.Product>

<h2 class="text-center my-4">@ViewBag.CategoryName Collection</h2>

<div class="container mt-4 text-center">
    <div class="d-flex justify-content-center flex-wrap gap-3 mb-5">
        
        @if (ViewBag.CategoryName == "Handbags")
        {
            <a href="/Shop/Category?name=Handbags" class="btn btn-outline-dark rounded-pill px-4">All Bags</a>
            <a href="/Shop/Category?name=Handbags&sub=Crossbody" class="btn btn-outline-dark rounded-pill px-4">Crossbody</a>
            <a href="/Shop/Category?name=Handbags&sub=Tote" class="btn btn-outline-dark rounded-pill px-4">Tote</a>
            <a href="/Shop/Category?name=Handbags&sub=Hobo" class="btn btn-outline-dark rounded-pill px-4">Hobo</a>
            <a href="/Shop/Category?name=Handbags&sub=Weekender" class="btn btn-outline-dark rounded-pill px-4">Weekender</a>
        }
        else if (ViewBag.CategoryName == "Makeup")
        {
            <a href="/Shop/Category?name=Makeup" class="btn btn-outline-dark rounded-pill px-4">All Makeup</a>
            <a href="/Shop/Category?name=Makeup&sub=Lipsticks" class="btn btn-outline-dark rounded-pill px-4">Lipsticks</a>
            <a href="/Shop/Category?name=Makeup&sub=Foundations" class="btn btn-outline-dark rounded-pill px-4">Foundations</a>
            <a href="/Shop/Category?name=Makeup&sub=Blushes" class="btn btn-outline-dark rounded-pill px-4">Blushes</a>
            <a href="/Shop/Category?name=Makeup&sub=Eyeshadows" class="btn btn-outline-dark rounded-pill px-4">Eyeshadows</a>
            <a href="/Shop/Category?name=Makeup&sub=Eyeliners" class="btn btn-outline-dark rounded-pill px-4">Eyeliners</a>
        }
        else if (ViewBag.CategoryName == "Clothing")
        {
            <a href="/Shop/Category?name=Clothing" class="btn btn-outline-dark rounded-pill px-4">All Clothing</a>
            <a href="/Shop/Category?name=Clothing&sub=Casual" class="btn btn-outline-dark rounded-pill px-4">Casual</a>
            <a href="/Shop/Category?name=Clothing&sub=Sport" class="btn btn-outline-dark rounded-pill px-4">Sport</a>
            <a href="/Shop/Category?name=Clothing&sub=Formal" class="btn btn-outline-dark rounded-pill px-4">Formal</a>
            <a href="/Shop/Category?name=Clothing&sub=Elegant" class="btn btn-outline-dark rounded-pill px-4">Elegant</a>
        }
    </div>
</div>

<div class="container mb-4">
    <div class="row justify-content-end">
        <div class="col-md-3">
            <form method="get" asp-action="Category">
                <input type="hidden" name="name" value="@ViewBag.CategoryName" />
                <input type="hidden" name="sub" value="@ViewBag.CurrentSubCategory" />
                <select name="sortOrder" class="form-select" onchange="this.form.submit()">
                    <option value="">Sort By: Default</option>
                    <option value="price_low">Price: Low to High</option>
                    <option value="price_high">Price: High to Low</option>
                </select>
            </form>
        </div>
    </div>
</div>

<div class="container">
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 text-center">
                    <img src="@item.ImageUrl" class="card-img-top bg-light" style="height: 250px; object-fit: contain; padding: 15px;" alt="@item.Name">
                    
                    <div class="card-body d-flex flex-column">
                        <div class="mb-2">
                            @if (item.StockQuantity > 5)
                            {
                                <span class="badge bg-success">In Stock</span>
                            }
                            else if (item.StockQuantity > 0)
                            {
                                <span class="badge bg-warning text-dark">Only @item.StockQuantity Left!</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Sold Out</span>
                            }
                        </div>

                        <h5 class="fw-bold">@item.Name</h5>
                        <p class="text-success fw-bold">Rs. @item.Price.ToString("N2")</p>
                        
                        <div class="mt-auto">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-dark w-100">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>