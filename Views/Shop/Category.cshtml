@model IEnumerable<LuxeFemStore.Models.Product>

<h2 class="text-center my-4">@ViewBag.CategoryName Collection</h2>

<div class="container mb-4">
    <div class="row justify-content-end">
        <div class="col-md-3">
            <form method="get" asp-action="Category">
                <input type="hidden" name="name" value="@ViewBag.CategoryName" />
                <select name="sortOrder" class="form-select" onchange="this.form.submit()">
                    <option value="">Sort By: Default</option>
                    <option value="price_low">Price: Low to High</option>
                    <option value="price_high">Price: High to Low</option>
                </select>
            </form>
        </div>
    </div>
</div>

<div class="container">
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 text-center">
                    <img src="@item.ImageUrl" class="card-img-top bg-light" style="height: 250px; object-fit: contain;padding:15px;" alt="@item.Name">
                    
                    <div class="card-body d-flex flex-column">
                        <div class="mb-2">
                            @if (item.StockQuantity > 5)
                            {
                                <span class="badge bg-success">In Stock</span>
                            }
                            else if (item.StockQuantity > 0)
                            {
                                <span class="badge bg-warning text-dark">Only @item.StockQuantity Left!</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Sold Out</span>
                            }
                        </div>

                        <h5>@item.Name</h5>
                        <p class="text-success fw-bold">$@item.Price</p>
                        
                        <div class="mt-auto">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-dark w-100">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>