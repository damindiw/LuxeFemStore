<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LuxeFemStore</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LuxeFemStore.styles.css" asp-append-version="true" />
    
    <style>
        /* Force Single-Line Layout */
        .navbar-container-custom {
            display: flex;
            align-items: center;
            justify-content: space-between;
            width: 100%;
            flex-wrap: nowrap !important;
        }

        .navbar-brand-custom {
            font-size: 1.6rem; 
            font-weight: 900;
            color: #FF69B4 !important; /* Hot Pink Brand Color */
            letter-spacing: -1px;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .navbar-nav {
            flex-direction: row !important;
            flex-wrap: nowrap !important;
            align-items: center;
        }

        .nav-link-custom {
            font-size: 0.9rem;
            font-weight: 500;
            color: #333 !important;
            transition: all 0.3s ease;
            position: relative;
            white-space: nowrap;
            padding-left: 10px !important;
            padding-right: 10px !important;
        }

        /* Underline Animation */
        .nav-link-custom::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: 0;
            left: 0;
            background-color: #FF69B4;
            transition: width 0.3s ease;
        }

        .nav-link-custom:hover::after { width: 100%; }
        .nav-link-custom:hover { color: #FF69B4 !important; }

        .shop-highlight {
            color: #000 !important;
            font-weight: 700;
        }

        /* Compact Search Bar Alignment */
        .search-container {
            max-width: 180px;
            margin-left: 15px;
        }
        
        .search-container .form-control {
            border-radius: 20px 0 0 20px !important;
            border-color: #ddd;
            font-size: 0.85rem;
        }

        .search-container .btn-search {
            border-radius: 0 20px 20px 0 !important;
            background-color: #212529;
            color: white;
            border: none;
        }

        /* Logout Button Appearance */
        .btn-logout-nav {
            font-size: 0.8rem;
            padding: 5px 15px;
            margin-left: 10px;
            white-space: nowrap;
        }

        /* --- RESTORED SOCIAL MEDIA COLORS --- */
        .social-link i { font-size: 24px; transition: transform 0.3s; }
        .fa-facebook { color: #1877F2 !important; } /* Official Facebook Blue */
        .fa-instagram {
            background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        } /* Official Instagram Gradient */
        .fa-whatsapp { color: #25D366 !important; } /* Official WhatsApp Green */
        
        .social-link:hover { transform: scale(1.1); }

        html, body { height: 100%; }
    </style>
</head>
<body class="d-flex flex-column h-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm py-2">
            <div class="container navbar-container-custom">
                
                <a class="navbar-brand navbar-brand-custom" asp-controller="Home" asp-action="Index">LuxeFemStore</a>
                
                <div class="d-flex align-items-center">
                    <ul class="navbar-nav me-2">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        
                        @using Microsoft.AspNetCore.Http
                        @{ var userName = Context.Session.GetString("UserName"); }

                        @if (!string.IsNullOrEmpty(userName))
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom shop-highlight" asp-controller="Shop" asp-action="Index">Shop Fashion</a>
                            </li>
                            /* GREETING REMOVED AS REQUESTED */
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-controller="Account" asp-action="SignIn">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-controller="Account" asp-action="SignUp">Register</a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="Home" asp-action="About">About Us</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="Home" asp-action="Help">Help</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="Home" asp-action="Contact">Contact</a>
                        </li>
                    </ul>

                    <form class="d-flex search-container" asp-controller="Shop" asp-action="Search" method="get">
                        <div class="input-group input-group-sm">
                            <input class="form-control" type="search" name="query" placeholder="Search...">
                            <button class="btn btn-search" type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </form>

                    @if (!string.IsNullOrEmpty(userName))
                    {
                        <a class="btn btn-sm btn-outline-danger rounded-pill btn-logout-nav" asp-controller="Account" asp-action="Logout">Logout</a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1 mt-4">
        <main role="main" class="pb-3">
            @RenderBody() 
        </main>
    </div>

    <footer class="bg-dark text-light pt-5 pb-4 mt-5">
        <div class="container">
            <div class="row text-center text-md-start">
                <div class="col-md-3 mt-3">
                    <h5 class="text-uppercase mb-4 font-weight-bold text-warning">LuxeFemStore</h5>
                    <p>Your one-stop destination for premium fashion. We bring luxury to your doorstep.</p>
                </div>

                <div class="col-md-2 mx-auto mt-3">
                    <h5 class="text-uppercase mb-4 font-weight-bold text-white">Support</h5>
                    <p><a asp-controller="Home" asp-action="About" class="text-light" style="text-decoration: none;">About Us</a></p>
                    <p><a asp-controller="Home" asp-action="Privacy" class="text-light" style="text-decoration: none;">Privacy Policy</a></p>
                    <p><a asp-controller="Home" asp-action="Terms" class="text-light" style="text-decoration: none;">Terms of Service</a></p>
                    <p><a asp-controller="Home" asp-action="Help" class="text-light" style="text-decoration: none;">Help Center</a></p>
                </div>

                <div class="col-md-3 mt-3">
                    <h5 class="text-uppercase mb-4 font-weight-bold text-white">Contact</h5>
                    <p><i class="fas fa-home me-3 text-warning"></i> Colombo, Sri Lanka</p>
                    <p><i class="fas fa-envelope me-3 text-warning"></i> support@luxefem.com</p>
                </div>

                <div class="col-md-3 mt-3 text-center">
                    <h5 class="text-uppercase mb-4 font-weight-bold text-white">Follow Us</h5>
                    <div class="mb-4">
                        <a href="#" class="social-link me-3"><i class="fab fa-facebook"></i></a>
                        <a href="#" class="social-link me-3"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="social-link"><i class="fab fa-whatsapp"></i></a>
                    </div>
                </div>
            </div>
            <hr class="my-4 border-secondary">
            <div class="row">
                <div class="col-12 text-center">
                    <p class="small text-muted mb-0">© 2026 LuxeFemStore. All Rights Reserved.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>