@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="py-5 mb-5 bg-light border-bottom">
    <div class="container text-center">
        <h1 class="display-4 fw-bold text-dark">Privacy Policy</h1>
        <p class="lead text-muted">How we handle and protect your personal information at LuxeFemStore.</p>
        <div class="mt-3">
            <span class="badge bg-dark px-3 py-2">Last Updated: March 2026</span>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            
            <div class="mb-5">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-warning p-2 rounded me-3">
                        <i class="fas fa-shield-alt text-dark fs-4"></i>
                    </div>
                    <h3 class="fw-bold m-0">Our Commitment</h3>
                </div>
                <p class="text-muted">At LuxeFemStore, your privacy is our priority. We are committed to protecting the personal data you share with us while browsing our collection of handbags, makeup, and fashion materials. This policy explains what information we collect and how it is used to improve your shopping experience.</p>
            </div>

            <div class="card border-0 shadow-sm mb-5">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-4">Information We Collect</h4>
                    <div class="row g-4">
                        <div class="col-md-6">
                            <h6 class="fw-bold"><i class="fas fa-user me-2 text-warning"></i> Personal Info</h6>
                            <p class="small text-muted">Name, email address, and phone number provided during account creation or checkout.</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="fw-bold"><i class="fas fa-map-marker-alt me-2 text-warning"></i> Delivery Data</h6>
                            <p class="small text-muted">Your shipping address in Colombo or other regions to ensure accurate delivery of your items.</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="fw-bold"><i class="fas fa-credit-card me-2 text-warning"></i> Payment Details</h6>
                            <p class="small text-muted">Secured processing of Visa, Mastercard, and Amex via encrypted gateways.</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="fw-bold"><i class="fas fa-cookie-bite me-2 text-warning"></i> Cookies</h6>
                            <p class="small text-muted">Usage data to remember your preferences and keep items in your shopping bag.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mb-5">
                <h4 class="fw-bold mb-3">How We Use Your Data</h4>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item bg-transparent"><i class="fas fa-check text-success me-2"></i> To process and fulfill your fashion orders.</li>
                    <li class="list-group-item bg-transparent"><i class="fas fa-check text-success me-2"></i> To send tracking updates and order confirmations.</li>
                    <li class="list-group-item bg-transparent"><i class="fas fa-check text-success me-2"></i> To improve our website design and product recommendations.</li>
                    <li class="list-group-item bg-transparent"><i class="fas fa-check text-success me-2"></i> To communicate special offers (if you opt-in).</li>
                </ul>
            </div>

            <div class="alert alert-dark p-4 border-0 rounded-3">
                <div class="d-flex align-items-center">
                    <i class="fas fa-info-circle fs-2 me-3 text-warning"></i>
                    <div>
                        <h5 class="fw-bold mb-1">Questions about your privacy?</h5>
                        <p class="mb-0 text-light opacity-75">Contact our support team at <strong>support@luxefem.com</strong> for any data-related concerns.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>